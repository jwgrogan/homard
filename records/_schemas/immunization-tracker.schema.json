{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "records/_schemas/immunization-tracker.schema.json",
  "title": "Pediatric Immunization Tracker",
  "type": "object",
  "required": ["child_id", "child_name", "as_of", "records"],
  "properties": {
    "child_id": { "type": "string" },
    "child_name": { "type": "string" },
    "as_of": { "type": "string", "format": "date" },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["vaccine", "status", "history_confidence", "sources"],
        "properties": {
          "vaccine": { "type": "string" },
          "series": { "type": "string" },
          "dose": { "type": ["integer", "string"] },
          "status": {
            "type": "string",
            "enum": ["completed", "due", "overdue", "unknown", "not_due", "contraindicated"]
          },
          "history_confidence": {
            "type": "string",
            "enum": ["confirmed", "partial", "unknown"]
          },
          "date": { "type": ["string", "null"], "format": "date" },
          "provider": { "type": ["string", "null"] },
          "due_date": { "type": ["string", "null"], "format": "date" },
          "notes": { "type": "string" },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["document", "type"],
              "properties": {
                "document": { "type": "string" },
                "type": {
                  "type": "string",
                  "enum": ["immunization_card", "clinic_summary", "portal_export", "school_form", "parent_report"]
                },
                "captured_on": { "type": ["string", "null"], "format": "date" },
                "location": { "type": ["string", "null"] }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
